# ---------------------------------------------------------------------------
# Railway environment variables for the OpenEMR service.
#
# Reference only — Railway variables are set in the service's "Variables" tab
# (or via `railway variables --set KEY=VALUE`), NOT committed to the repo. Copy
# the keys below into that tab. Values shown as ${{ MySQL.VAR }} are Railway
# reference variables; replace "MySQL" with the actual name of your database
# service. See docker/railway/README.md.
# ---------------------------------------------------------------------------

# --- Database connection (from the Railway MySQL service) ------------------
# Required. OpenEMR bootstraps the schema on first boot using the root pass.
MYSQL_HOST=${{ MySQL.MYSQLHOST }}
MYSQL_PORT=${{ MySQL.MYSQLPORT }}
MYSQL_ROOT_PASS=${{ MySQL.MYSQL_ROOT_PASSWORD }}
MYSQL_DATABASE=${{ MySQL.MYSQLDATABASE }}

# Optional; default to "openemr"/"openemr" if omitted.
MYSQL_USER=${{ MySQL.MYSQLUSER }}
MYSQL_PASS=${{ MySQL.MYSQLPASSWORD }}

# --- Initial OpenEMR admin login -------------------------------------------
OE_USER=admin
# CHANGE THIS before exposing the deploy publicly — do not ship the "pass" default.
OE_PASS=change-me-to-a-strong-password

# --- Optional features / hardening -----------------------------------------
# Enable the REST API used by the Clinical Co-Pilot feature.
OPENEMR_SETTING_rest_api=1

# Require TLS to the database (ensure the DB is configured for it).
# FORCE_DATABASE_SSL_CONNECT=1

# Offload PHP sessions to a Redis service (needed for >1 replica).
# REDIS_SERVER=${{ Redis.REDISHOST }}
# REDIS_PASSWORD=${{ Redis.REDISPASSWORD }}
