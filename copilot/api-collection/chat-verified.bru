meta {
  name: 3 Chat - code status
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/chat
  body: json
}

headers {
  Authorization: Bearer {{token}}
  X-Clinician-Id: {{clinician}}
}

body:json {
  {
    "patient_id": "{{patient}}",
    "message": "What is this patient's code status and goals of care?",
    "session_id": "demo-1"
  }
}

docs {
  Verified turn -> 200 with cited answer and degraded=false. If the LLM is
  unavailable the sidecar returns the recent-visit fallback with degraded=true.
}
